  "tokenColors": [
    { "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#383848", "fontStyle": "italic" } },
    { "name": "String",
      "scope": ["string", "string.template"],
      "settings": { "foreground": "#9090A8" } },
    { "name": "String escape / regexp",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#B0B0C8" } },
    { "name": "Number / Bool / Null",
      "scope": ["constant.numeric", "constant.language"],
      "settings": { "foreground": "#8090A0" } },
    { "name": "Keyword",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#E0203A", "fontStyle": "bold" } },
    { "name": "Control flow",
      "scope": ["keyword.control"],
      "settings": { "foreground": "#C01030", "fontStyle": "bold" } },
    { "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#705060" } },
    { "name": "Function definition",
      "scope": ["entity.name.function"],
      "settings": { "foreground": "#D8D8E8", "fontStyle": "bold" } },
    { "name": "Function call",
      "scope": ["meta.function-call entity.name.function", "support.function"],
      "settings": { "foreground": "#B0B0C8" } },
    { "name": "Class / Type",
      "scope": ["entity.name.class", "entity.name.type", "support.class"],
      "settings": { "foreground": "#C8C8D8", "fontStyle": "bold" } },
    { "name": "Interface / Enum",
      "scope": ["entity.name.interface", "entity.name.enum"],
      "settings": { "foreground": "#A0A0B8" } },
    { "name": "Type annotation",
      "scope": ["meta.type.annotation", "support.type"],
      "settings": { "foreground": "#808098" } },
    { "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#C8C8D0" } },
    { "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#A8A8B8", "fontStyle": "italic" } },
    { "name": "Property",
      "scope": ["variable.other.property", "support.type.property-name"],
      "settings": { "foreground": "#909098" } },
    { "name": "Decorator",
      "scope": ["meta.decorator"],
      "settings": { "foreground": "#C01030AA", "fontStyle": "italic" } },
    { "name": "Tag",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#C01030" } },
    { "name": "Tag attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#808098" } },
    { "name": "CSS property",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#7878A0" } },
    { "name": "CSS value",
      "scope": ["meta.property-value.css"],
      "settings": { "foreground": "#9090A8" } },
    { "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": { "foreground": "#3A3A50" } },
    { "name": "Markdown heading",
      "scope": ["markup.heading"],
      "settings": { "foreground": "#E0203A", "fontStyle": "bold" } },
    { "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#D8D8E8", "fontStyle": "bold" } },
    { "name": "Markdown link",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#C01030" } },
    { "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#909098" } },
    { "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#FF2040", "fontStyle": "underline" } }
  ],

  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class":         { "foreground": "#C8C8D8", "bold": true },
    "interface":     { "foreground": "#A0A0B8" },
    "enum":          { "foreground": "#A0A0B8" },
    "enumMember":    { "foreground": "#8090A0" },
    "type":          { "foreground": "#808098" },
    "parameter":     { "foreground": "#A8A8B8", "italic": true },
    "variable":      { "foreground": "#C8C8D0" },
    "property":      { "foreground": "#909098" },
    "function":      { "foreground": "#B0B0C8" },
    "method":        { "foreground": "#B0B0C8" },
    "keyword":       { "foreground": "#E0203A", "bold": true },
    "comment":       { "foreground": "#383848", "italic": true },
    "string":        { "foreground": "#9090A8" },
    "number":        { "foreground": "#8090A0" },
    "operator":      { "foreground": "#705060" }
  }
}