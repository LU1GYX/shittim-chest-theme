  "tokenColors": [
    { "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#7AAFC8", "fontStyle": "italic" } },
    { "name": "String",
      "scope": ["string", "string.template"],
      "settings": { "foreground": "#007A99" } },
    { "name": "String escape / regexp",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#009AB8" } },
    { "name": "Number / Bool / Null",
      "scope": ["constant.numeric", "constant.language"],
      "settings": { "foreground": "#00889A" } },
    { "name": "Keyword",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#005B8A", "fontStyle": "bold" } },
    { "name": "Control flow",
      "scope": ["keyword.control"],
      "settings": { "foreground": "#00729A", "fontStyle": "bold" } },
    { "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#3399BB" } },
    { "name": "Function definition",
      "scope": ["entity.name.function"],
      "settings": { "foreground": "#005577", "fontStyle": "bold" } },
    { "name": "Function call",
      "scope": ["meta.function-call entity.name.function", "support.function"],
      "settings": { "foreground": "#007799" } },
    { "name": "Class / Type",
      "scope": ["entity.name.class", "entity.name.type", "support.class"],
      "settings": { "foreground": "#005B8A", "fontStyle": "bold" } },
    { "name": "Interface / Enum",
      "scope": ["entity.name.interface", "entity.name.enum"],
      "settings": { "foreground": "#0066AA" } },
    { "name": "Type annotation",
      "scope": ["meta.type.annotation", "support.type"],
      "settings": { "foreground": "#2288AA" } },
    { "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#1A3A5C" } },
    { "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#2A5A7A", "fontStyle": "italic" } },
    { "name": "Property",
      "scope": ["variable.other.property", "support.type.property-name"],
      "settings": { "foreground": "#006688" } },
    { "name": "Decorator",
      "scope": ["meta.decorator"],
      "settings": { "foreground": "#00AACCAA", "fontStyle": "italic" } },
    { "name": "Tag",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#005B8A" } },
    { "name": "Tag attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#007799" } },
    { "name": "CSS property",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#0088AA" } },
    { "name": "CSS value",
      "scope": ["meta.property-value.css"],
      "settings": { "foreground": "#007A88" } },
    { "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": { "foreground": "#6AAAC8" } },
    { "name": "Markdown heading",
      "scope": ["markup.heading"],
      "settings": { "foreground": "#005577", "fontStyle": "bold" } },
    { "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#004466", "fontStyle": "bold" } },
    { "name": "Markdown link",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#00AACC" } },
    { "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#006688" } },
    { "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#CC3366", "fontStyle": "underline" } }
  ],

  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class":         { "foreground": "#005B8A", "bold": true },
    "interface":     { "foreground": "#0066AA" },
    "enum":          { "foreground": "#0066AA" },
    "enumMember":    { "foreground": "#00889A" },
    "type":          { "foreground": "#2288AA" },
    "parameter":     { "foreground": "#2A5A7A", "italic": true },
    "variable":      { "foreground": "#1A3A5C" },
    "property":      { "foreground": "#006688" },
    "function":      { "foreground": "#007799" },
    "method":        { "foreground": "#007799" },
    "keyword":       { "foreground": "#005B8A", "bold": true },
    "comment":       { "foreground": "#7AAFC8", "italic": true },
    "string":        { "foreground": "#007A99" },
    "number":        { "foreground": "#00889A" },
    "operator":      { "foreground": "#3399BB" }
  }
}
